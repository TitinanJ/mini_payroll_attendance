<div class="flex flex-col max-w-5xl mx-auto">
  <div class="mb-6">
    <%= link_to employees_path, class: "text-gray-600 hover:underline hover:text-gray-800 text-sm" do %>
      <%= heroicon "arrow-left", variant: :outline, options: { class: "h-4 w-4 inline-block mr-1" } %>
      Back
    <% end %>
  </div>

  <div class="bg-white rounded-xl shadow px-16 py-10">
    <h1 class="text-2xl font-bold text-gray-800 mb-6">Edit Employee</h1>
    <%= render "form", employee: @employee %>
  </div>
</div>
