<div class="max-w-5xl mx-auto">
    <%# Header %>
    <div class="flex items-center justify-between mb-6">
      <%= link_to employee_path(@employee), class: "text-gray-600 hover:text-gray-800 text-sm" do %>
        <%= heroicon "arrow-left", variant: :outline, options: { class: "h-4 w-4 inline-block mr-1" } %>
        Back
      <% end %>
      <h1 class="text-2xl font-bold text-gray-800"><%= @employee.name %> — Attendance</h1>
    </div>
  
    <%# Check-in / Checkout Card %>
    <div class="bg-white rounded-xl shadow px-8 py-6 mb-6">
      <% if @pending_attendance %>
        <%# checked-in, show checkout form %>
        <p class="text-gray-600 text-sm mb-3">
          Checked in at <strong><%= @pending_attendance.check_in_at.strftime("%Y-%m-%d %H:%M") %></strong> — ready to check out
        </p>
        <%= form_with url: checkout_attendance_path(@pending_attendance), method: :patch do |form| %>
          <div class="flex items-end gap-4">
            <div>
              <%= form.label :check_out_at, "Check-out time", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= form.datetime_local_field :check_out_at, value: Time.current.strftime("%Y-%m-%dT%H:%M"), class: "border border-gray-300
  rounded-lg px-4 py-2 text-sm" %>
            </div>
            <%= form.submit "Check Out", class: "bg-gray-800 hover:bg-gray-900 text-white text-sm font-medium px-6 py-2 rounded-lg
  cursor-pointer" %>
          </div>
        <% end %>

      <% else %>
        <%# not checked in yet, show check-in form %>
        <% if @attendance&.errors&.any? %>
          <div class="mb-4 text-red-600 text-sm">
            <% @attendance.errors.full_messages.each do |msg| %>
              <p><%= msg %></p> 
            <% end %>
          </div>
        <% end %>
        <%= form_with url: employee_attendances_path(@employee), method: :post do |form| %>
          <div class="flex items-end gap-4">
            <div>
              <%= form.label :check_in_at, "Check-in time", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= form.datetime_local_field :check_in_at, value: Time.current.strftime("%Y-%m-%dT%H:%M"), class: "border border-gray-300
  rounded-lg px-4 py-2 text-sm" %>
            </div>
            <%= form.submit "Check In", class: "bg-gray-800 hover:bg-gray-900 text-white text-sm font-medium px-6 py-2 rounded-lg
  cursor-pointer" %>
          </div>
        <% end %>
      <% end %>
    </div>

    <%# Attendance Table %>
    <div class="bg-white rounded-xl shadow overflow-hidden px-6 py-6">
      <div class="pb-4 border-b border-gray-200 flex items-center justify-between">
        <span class="text-gray-600 text-sm block border-gray-200">
          Attendance records for <strong><%= Date::MONTHNAMES[@month] %> <%= @year %></strong>
        </span>
        <%= form_with url: employee_attendances_path(@employee), method: :get, data: { turbo: false } do |form| %>
          <div class="flex gap-2">
            <%= form.select :month, (1..12).map { |m| [Date::MONTHNAMES[m], m] },
                { selected: @month },
                { class: "border border-gray-300 rounded-lg px-3 py-2 text-sm", onchange: "this.form.submit()" } %>
            <%= form.select :year, (Date.today.year - 2..Date.today.year).map { |y| [y, y] },
                { selected: @year },
                { class: "border border-gray-300 rounded-lg px-3 py-2 text-sm", onchange: "this.form.submit()" } %>
          </div>
        <% end %>
      </div>

      <table class="w-full text-sm text-left shadow-sm rounded-lg">
        <thead class="bg-gray-200 text-gray-800 uppercase text-xs tracking-wider">
          <tr>
            <th class="px-6 py-4">Date</th>
            <th class="px-6 py-4">Check-in</th>
            <th class="px-6 py-4">Check-out</th>
            <th class="px-6 py-4">Hours</th>
            <th class="px-6 py-4">OT Hours</th>
            <th class="px-6 py-4">Status</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @attendances.each do |attendance| %>
            <tr class="hover:bg-gray-50 transition-colors">
              <td class="px-6 py-4"><%= attendance.work_date.strftime("%d %b %Y") %></td>
              <td class="px-6 py-4"><%= attendance.check_in_at.strftime("%H:%M") %></td>
              <td class="px-6 py-4"><%= attendance.check_out_at&.strftime("%H:%M") || "-" %></td>
              <td class="px-6 py-4">
                <% if attendance.check_out_at %>
                  <%= ((attendance.check_out_at - attendance.check_in_at) / 3600.0).round(1) %> hrs
                <% else %>
                  -
                <% end %>
              </td>
              <td class="px-6 py-4"><%= attendance.overtime_hours&.round(1) || "-" %></td>
              <td class="px-6 py-4">
                <% if attendance.check_out_at %>
                  <span class="bg-green-100 text-green-700 px-2 py-1 rounded-md text-xs">Completed</span>
                <% else %>
                  <span class="bg-yellow-100 text-yellow-700 px-2 py-1 rounded-md text-xs">In Progress</span>
                <% end %>
              </td>   
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>